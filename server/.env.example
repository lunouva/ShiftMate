# Server env vars (copy to .env)
# Required for Live backend mode

# Postgres
# Example: postgres://user:password@localhost:5432/shiftway
DATABASE_URL=postgres://postgres:postgres@localhost:5432/shiftway

# Optional DB connection tuning (helps production stability)
# DB_POOL_MAX=10
# DB_CONNECT_TIMEOUT_MS=10000
# DB_IDLE_TIMEOUT_MS=30000
# DB_SSL=require

# Server
PORT=4000
# Where the frontend is running (used in links + OAuth callbacks)
APP_URL=http://localhost:5173
# Optional comma-separated allowlist for additional frontend origins (CORS)
# APP_ALLOWED_ORIGINS=https://app.shiftway.com,https://preview.shiftway.com

# Auth/session (use strong values in production)
JWT_SECRET=dev-secret
SESSION_SECRET=dev-session
# JWT access token lifetime (short-lived access + refresh)
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL_DAYS=30
# REQUIRE_EMAIL_VERIFICATION=0
# DEBUG_EMAIL_LAST_ENABLED=1

# Optional integrations (leave blank to disable)
# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=

# SMTP (password-reset / email notifications)
# SMTP_URL=smtp://user:pass@smtp.example.com:587
# EMAIL_FROM=Shiftway <no-reply@example.com>
# SMTP_CONNECTION_TIMEOUT_MS=5000
# SMTP_GREETING_TIMEOUT_MS=5000
# SMTP_SOCKET_TIMEOUT_MS=15000
# SMTP_SEND_TIMEOUT_MS=8000
# EMAIL_MAX_RETRIES=3
# EMAIL_RETRY_BASE_DELAY_MS=750
# PASSWORD_RESET_TTL_MINUTES=30
# EMAIL_VERIFICATION_TTL_HOURS=24
# MAGIC_LINK_TTL_MINUTES=15

# Twilio (SMS notifications)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

# Web Push (browser push notifications)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# ── SaaS / Billing ──────────────────────────────────────────
# Stripe secret key (sk_live_... or sk_test_...)
# STRIPE_SECRET_KEY=

# Stripe webhook signing secret (from `stripe listen` or Stripe dashboard)
# STRIPE_WEBHOOK_SECRET=

# Legacy fallback for Core monthly if you have not split plan IDs yet
# STRIPE_PRICE_ID=

# Stripe Price IDs by plan and billing period
# STRIPE_PRICE_ID_FREE=
# STRIPE_PRICE_ID_FREE_MONTHLY=
# STRIPE_PRICE_ID_FREE_YEARLY=
# STRIPE_PRICE_ID_CORE_MONTHLY=
# STRIPE_PRICE_ID_CORE_YEARLY=
# STRIPE_PRICE_ID_PRO_MONTHLY=
# STRIPE_PRICE_ID_PRO_YEARLY=
# STRIPE_PRICE_ID_ENTERPRISE_MONTHLY=
# STRIPE_PRICE_ID_ENTERPRISE_YEARLY=

# Number of trial days granted at signup (default: 14)
# TRIAL_DAYS=14
# BILLING_SUCCESS_URL=http://localhost:5173/billing/success
# BILLING_CANCEL_URL=http://localhost:5173/billing/cancel

# Public domain for SaaS subdomains (e.g. shiftway.app)
# SAAS_DOMAIN=shiftway.app
# GOOGLE_STATE_TTL_MINUTES=10
